   "source": [
    "@torch.inference_mode()\n",
    "def get_fused_crops(image_tensor, detectors, score_thresh=0.5, nms_iou=0.5):\n",
    "    \"\"\"\n",
    "    Run all 4 detectors on one image, fuse boxes with NMS,\n",
    "    return a list of cropped particle tensors (fp32, CPU).\n",
    "    \"\"\"\n",
    "    all_boxes, all_scores = [], []\n",
    "    img_gpu = image_tensor.to(device)          # (C, H, W) fp32\n",
    "\n",
    "    for det in detectors.values():\n",
    "        out    = det([img_gpu])\n",
    "        boxes  = out[0][\"boxes\"]\n",
    "        scores = out[0][\"scores\"]\n",
    "        keep   = scores > score_thresh\n",
    "        if keep.any():\n",
    "            all_boxes.append(boxes[keep].cpu())\n",
    "            all_scores.append(scores[keep].cpu())\n",
    "\n",
    "    if not all_boxes:\n",
    "        return []\n",
    "\n",
    "    all_boxes_t  = torch.cat(all_boxes,  dim=0).float()\n",
    "    all_scores_t = torch.cat(all_scores, dim=0).float()\n",
    "    keep_idx     = torchvision.ops.nms(all_boxes_t, all_scores_t, nms_iou)\n",
    "\n",
    "    crops = []\n",
    "    for i in keep_idx:\n",
    "        x1, y1, x2, y2 = all_boxes_t[i].int().tolist()\n",
    "        x1 = max(0, x1); y1 = max(0, y1)\n",
    "        x2 = max(x1+1, x2); y2 = max(y1+1, y2)\n",
    "        crop = image_tensor[:, y1:y2, x1:x2]\n",
    "        if crop.shape[1] >= 10 and crop.shape[2] >= 10:\n",
    "            crops.append(crop)\n",
    "    return crops\n",
    "\n",
    "\n",
    "@torch.inference_mode()\n",
    "def classify_crops(crops, classifiers, model_weights, device):\n",
    "    \"\"\"\n",
    "    For each crop: weighted ensemble over all 8 classifiers (fp16).\n",
    "    Returns list of per-crop probability tensors (fp32, GPU).\n",
    "    \"\"\"\n",
    "    results = []\n",
    "    for crop in crops:\n",
    "        # Resize + convert to fp16\n",
    "        crop_fp16 = (F.interpolate(crop.unsqueeze(0).to(device),\n",
    "                                    size=(224, 224))\n",
    "                      .half())\n",
    "        w_sum = None\n",
    "        for name, model in classifiers.items():\n",
    "            probs = torch.softmax(model(crop_fp16).float(), dim=1)\n",
    "            w     = model_weights[name]\n",
    "            w_sum = w * probs if w_sum is None else w_sum + w * probs\n",
    "        results.append(w_sum)          # (1, 22)\n",
    "    return results\n",
    "\n",
    "\n",
    "@torch.inference_mode()\n",
    "def hybrid_single(image_tensor, detectors, classifiers, model_weights, device):\n",
    "    \"\"\"\n",
    "    Full hybrid inference for ONE image tensor (C,H,W).\n",
    "    Falls back to full-image ensemble when no particles detected.\n",
    "    Returns (pred_class: int, prob_vector: np.ndarray [22])\n",
    "    \"\"\"\n",
    "    crops = get_fused_crops(image_tensor, detectors)\n",
    "\n",
    "    if crops:\n",
    "        per_crop = classify_crops(crops, classifiers, model_weights, device)\n",
    "        avg_prob = sum(per_crop) / len(per_crop)\n",
    "    else:\n",
    "        # ── Fallback: full-image weighted ensemble ───────────────────\n",
    "        img_fp16 = (F.interpolate(image_tensor.unsqueeze(0).to(device),\n",
    "                                   size=(224, 224))\n",
    "                     .half())\n",
    "        avg_prob = None\n",
    "        for name, model in classifiers.items():\n",
    "            p = torch.softmax(model(img_fp16).float(), dim=1)\n",
    "            avg_prob = (model_weights[name] * p if avg_prob is None\n",
    "                        else avg_prob + model_weights[name] * p)\n",
    "\n",
    "    pred  = avg_prob.argmax(1).item()\n",
    "    probs = avg_prob.squeeze(0).cpu().float().numpy()\n",
    "    return pred, probs\n",
    "\n",
    "print(\"Hybrid inference functions defined  ✓\")"
   ]
